{
  "mcpServers": {
    "shadcn": {
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ]
    },
    "colorsandfonts": {
      "command": "npx",
      "args": [
        "-y",
        "@colorsandfonts/mcp"
      ]
    },
    "Payload": {
      "type": "http",
      "url": "http://127.0.0.1:3000/api/mcp",
      "headers": {
        "Authorization": "Bearer ${PAYLOAD_MCP_API_KEY}"
      }
    }
  }
}